<!DOCTYPE html> 

<html> 

<head> 

<title>Email Address Generator</title> 

 

<script> 

function generateEmail(btn) 

{ 

    var form = btn.form; 

 

    var fname = form.elements["firstname"].value; 

    var lname = form.elements["lastname"].value; 

 

    var email = fname + "." + lname + "@park.edu"; 

 

    document.getElementById("result").innerHTML = "Generated Email: " + email; 

 

    form.reset(); 

 

    form.elements["firstname"].focus(); 

} 

</script> 

 

</head> 

 

<body> 

 

<h3>Name: LOKITHA SRIKIREDDY</h3> 

<h3>Registration No: 24BCE0074</h3> 

 

<h2>Email Address Generator</h2> 

 

<form> 

 

First Name: 

<input type="text" name="firstname"><br><br> 

 

Last Name: 

<input type="text" name="lastname"><br><br> 

 

<input type="button" value="Generate Email" onclick="generateEmail(this)"> 

 

</form> 

 

<p id="result"></p> 

 

</body> 

</html> 

 

 
