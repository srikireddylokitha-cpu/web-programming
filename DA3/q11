<!DOCTYPE html> 

<html> 

<head> 

<title>Simple Interest Calculator</title> 

 

<script> 

function simpleInterest(p, r, t) 

{ 

    var si = (p * r * t) / 100; 

    return si; 

} 

 

function calculateSI() 

{ 

    var principal = document.getElementById("principal").value; 

    var rate = document.getElementById("rate").value; 

    var time = document.getElementById("time").value; 

 

    var result = simpleInterest(principal, rate, time); 

 

    document.getElementById("result").innerHTML = 

    "Simple Interest = " + result; 

} 

</script> 

 

</head> 

 

<body> 

 

<h3>Name: LOKITHA SRIKIREDDY</h3> 

<h3>Registration No: 24BCE0074</h3> 

 

<h2>Simple Interest Calculator</h2> 

 

<label>Principal Amount:</label> 

<input type="number" id="principal"><br><br> 

 

<label>Rate of Interest:</label> 

<input type="number" id="rate"><br><br> 

 

<label>Time (in years):</label> 

<input type="number" id="time"><br><br> 

 

<button onclick="calculateSI()">Calculate Simple Interest</button> 

 

<p id="result"></p> 

 

</body> 

</html> 

 

 
