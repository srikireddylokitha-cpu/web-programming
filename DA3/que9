<!DOCTYPE html> 

<html> 

<head> 

<title>Radio Button Example</title> 

 

<script> 

function showColor() 

{ 

    var colors = document.getElementsByName("color"); 

    var selectedColor = ""; 

 

    for(var i = 0; i < colors.length; i++) 

    { 

        if(colors[i].checked) 

        { 

            selectedColor = colors[i].value; 

        } 

    } 

 

    document.getElementById("output").innerHTML = "Selected Color: " + selectedColor; 

} 

</script> 

 

</head> 

 

<body> 

 

<h3>Name: LOKITHA SRIKIREDDY</h3> 

<h3>Registration No: 24BCE0074/h3> 

 

<h2>Select a Color</h2> 

 

<input type="radio" name="color" value="Red"> Red<br> 

<input type="radio" name="color" value="Green"> Green<br> 

<input type="radio" name="color" value="Blue"> Blue<br><br> 

 

<button onclick="showColor()">Show Selected Color</button> 

 

<p id="output"></p> 

 

</body> 

</html> 

 

 
