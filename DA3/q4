!DOCTYPE html> 

<html> 

<head> 

<title>Area of Rectangle</title> 

 

<script> 

function calculateArea() 

{ 

    // Integer values 

    var lengthValue = 10; 

    var widthValue = 5; 

    var areaResult = lengthValue * widthValue; 

 

    // Floating-point values (loose typing) 

    lengthValue = 10.5; 

    widthValue = 5.2; 

    var floatAreaResult = lengthValue * widthValue; 

 

    document.getElementById("result").innerHTML = 

    "Area with integers: " + areaResult + "<br>" + 

    "Area with floating numbers: " + floatAreaResult; 

} 

</script> 

 

</head> 

 

<body> 

 

<h3>Name: LOKITHA SRIKIREDDY</h3> 

<h3>Registration No: 24BCE0074</h3> 

 

<h2>Rectangle Area Calculator</h2> 

 

<button onclick="calculateArea()">Calculate Area</button> 

 

<p id="result"></p> 

 

</body> 

</html> 

 

 

 
