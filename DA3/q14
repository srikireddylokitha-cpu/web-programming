<!DOCTYPE html> 

<html> 

<head> 

<title>Text Styling Application</title> 

 

<style> 

/* Predefined CSS classes */ 

.italic { 

    font-style: italic; 

} 

 

.bold { 

    font-weight: bold; 

} 

 

.smallcaps { 

    font-variant: small-caps; 

} 

</style> 

 

<script> 

function applyStyle(style) { 

    var message = document.getElementById("message"); 

 

    if (style === "reset") { 

        message.className = ""; // remove all styles 

    } else { 

        // assign multiple classes dynamically 

        message.className += (message.className ? " " : "") + style; 

    } 

} 

</script> 

 

</head> 

 

<body> 

 

<h3>Name: LOKITHA SRIKIREDDY</h3> 

<h3>Registration No: 24BCE0074</h3> 

 

<h2>Text Styling Application</h2> 

 

<fieldset> 

<legend>Message</legend> 

<p id="message">This is a sample message. Apply styles using the buttons below.</p> 

</fieldset> 

 

<fieldset> 

<legend>Apply Styles</legend> 

<button type="button" onclick="applyStyle('italic')">Italic</button> 

<button type="button" onclick="applyStyle('bold')">Bold</button> 

<button type="button" onclick="applyStyle('smallcaps')">Small-Caps</button> 

<button type="button" onclick="applyStyle('reset')">Reset</button> 

</fieldset> 

 

</body> 

</html> 

 

 
